<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:startColor="#2563EB"
                android:centerColor="#4F46E5"
                android:endColor="#06B6D4" />
            <stroke
                android:width="1dp"
                android:color="#F2FFFFFF" />
            <padding
                android:left="18dp"
                android:top="10dp"
                android:right="18dp"
                android:bottom="10dp" />
        </shape>
    </item>

    <item>
        <shape>
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:startColor="#3B82F6"
                android:centerColor="#6366F1"
                android:endColor="#22D3EE" />
            <stroke
                android:width="1dp"
                android:color="#E6FFFFFF" />
            <padding
                android:left="18dp"
                android:top="10dp"
                android:right="18dp"
                android:bottom="10dp" />
        </shape>
    </item>
</selector>
